# LinkedIn OAuth2 credentials
# Get these from https://developer.linkedin.com/ → Your App → Auth tab
LINKEDIN_CLIENT_ID="your_client_id_here"
LINKEDIN_CLIENT_SECRET="your_client_secret_here"

# LinkedIn access token (obtained by running: python oauth_helper.py)
LINKEDIN_ACCESS_TOKEN=""

# Your LinkedIn Person URN (obtained by running: python oauth_helper.py)
# Format: urn:li:person:XXXXXXXXX
LINKEDIN_PERSON_URN=""

# Optional: Custom path for the sync state file
# SYNC_STATE_FILE="/path/to/sync_state.json"

# LLM provider for summary mode ("anthropic" or "openai", default: anthropic)
# LLM_PROVIDER="anthropic"

# API key for the chosen LLM provider
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# Optional: Override the default model
# LLM_MODEL="claude-sonnet-4-20250514"  # for anthropic
# LLM_MODEL="gpt-4o"                    # for openai
