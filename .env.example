# Blog configuration
# Atom feed URL for your blog
BLOG_FEED_URL="https://eve.gd/feed/feed.atom"

# Base URL of your blog (used for resolving relative image paths and
# deriving URLs from Jekyll-style markdown filenames)
BLOG_SITE_URL="https://eve.gd"

# Optional: additional context about the blog author, injected into LLM
# prompts for more personalised summaries (e.g. "a professor who writes
# about open access and higher education")
# BLOG_AUTHOR_CONTEXT=""

# LinkedIn OAuth2 credentials
# Get these from https://developer.linkedin.com/ → Your App → Auth tab
LINKEDIN_CLIENT_ID="your_client_id_here"
LINKEDIN_CLIENT_SECRET="your_client_secret_here"

# LinkedIn access token (obtained by running: uv run linkedin-oauth)
LINKEDIN_ACCESS_TOKEN=""

# Your LinkedIn Person URN (obtained by running: uv run linkedin-oauth)
# Format: urn:li:person:XXXXXXXXX
LINKEDIN_PERSON_URN=""

# Bluesky credentials
# Handle: your Bluesky username (e.g. yourname.bsky.social)
# App password: create one at bsky.app → Settings → Privacy and Security
#   → App Passwords → Add App Password
BLUESKY_HANDLE=""
BLUESKY_APP_PASSWORD=""

# Mastodon credentials
# Instance URL: your Mastodon server (e.g. https://mastodon.social)
# Access token: create one at your instance → Preferences → Development
#   → New Application → set "write:statuses" scope → copy access token
MASTODON_INSTANCE_URL=""
MASTODON_ACCESS_TOKEN=""

# Optional: Custom path for the sync state file
# SYNC_STATE_FILE="/path/to/sync_state.json"

# LLM provider for summary mode ("anthropic" or "openai", default: anthropic)
# LLM_PROVIDER="anthropic"

# API key for the chosen LLM provider
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# Optional: Override the default model
# LLM_MODEL="claude-sonnet-4-20250514"  # for anthropic
# LLM_MODEL="gpt-4o"                    # for openai
