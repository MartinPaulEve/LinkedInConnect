# Blog configuration
# Atom feed URL for your blog
BLOG_FEED_URL="https://eve.gd/feed/feed.atom"

# Base URL of your blog (used for resolving relative image paths and
# deriving URLs from Jekyll-style markdown filenames)
BLOG_SITE_URL="https://eve.gd"

# Optional: additional context about the blog author, injected into LLM
# prompts for more personalised summaries (e.g. "a professor who writes
# about open access and higher education")
# BLOG_AUTHOR_CONTEXT=""

# LinkedIn OAuth2 credentials
# Get these from https://developer.linkedin.com/ → Your App → Auth tab
LINKEDIN_CLIENT_ID="your_client_id_here"
LINKEDIN_CLIENT_SECRET="your_client_secret_here"

# LinkedIn access token (obtained by running: uv run linkedin-oauth)
LINKEDIN_ACCESS_TOKEN=""

# Your LinkedIn Person URN (obtained by running: uv run linkedin-oauth)
# Format: urn:li:person:XXXXXXXXX
LINKEDIN_PERSON_URN=""

# Bluesky credentials
# Handle: your Bluesky username (e.g. yourname.bsky.social)
# App password: create one at bsky.app → Settings → Privacy and Security
#   → App Passwords → Add App Password
BLUESKY_HANDLE=""
BLUESKY_APP_PASSWORD=""

# Mastodon credentials
# Instance URL: your Mastodon server (e.g. https://mastodon.social)
# Access token: create one at your instance → Preferences → Development
#   → New Application → set "write:statuses" scope → copy access token
MASTODON_INSTANCE_URL=""
MASTODON_ACCESS_TOKEN=""

# Optional: Custom path for the sync state file
# SYNC_STATE_FILE="/path/to/sync_state.json"

# LLM provider for summary mode ("anthropic" or "openai", default: anthropic)
# LLM_PROVIDER="anthropic"

# API key for the chosen LLM provider
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# Optional: Override the default model
# LLM_MODEL="claude-sonnet-4-20250514"  # for anthropic
# LLM_MODEL="gpt-4o"                    # for openai

# ── Thread ellipsis settings ──────────────────────────────────────
# When a message is too long and gets split into a thread (on Bluesky
# or Mastodon), ellipsis markers ("...") are added to indicate that
# the post continues or is a continuation:
#
#   Post 1: Here is a post... 🧵1/2
#   Post 2: ... continued here 🧵2/2
#
# By default, both start and end ellipses are enabled.
#
# THREAD_ELLIPSES controls both start and end ellipses at once.
# Set to "false" to disable all ellipses, "true" to enable (default).
# THREAD_ELLIPSES="true"
#
# THREAD_START_ELLIPSES controls the "..." at the start of
# continuation posts (post 2 onwards).
# Set to "false" to disable, "true" to enable (default).
# THREAD_START_ELLIPSES="true"
#
# THREAD_END_ELLIPSES controls the "..." at the end of continued
# posts (all posts except the last).
# Set to "false" to disable, "true" to enable (default).
# THREAD_END_ELLIPSES="true"
#
# The specific keys (THREAD_START_ELLIPSES, THREAD_END_ELLIPSES)
# take priority over the blanket THREAD_ELLIPSES key. CLI flags
# (--no-ellipses, --no-start-ellipses, --no-end-ellipses) take
# the highest priority and override everything.
#
# Priority order (highest to lowest):
#   1. CLI flags (--no-ellipses, --no-start-ellipses, --no-end-ellipses)
#   2. Specific .env keys (THREAD_START_ELLIPSES, THREAD_END_ELLIPSES)
#   3. Blanket .env key (THREAD_ELLIPSES)
#   4. Built-in default (true)
